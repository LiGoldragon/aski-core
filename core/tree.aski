;; tree.aski — the data-tree and synth output
;;
;; SynthOutput is what askicc produces (first pass).
;; DataTree is what askic produces (second pass).

(tree SynthOutput DataTree)

;; ── First Pass Output (askicc) ──────────────────────────────────

{SynthOutput
  Scope
  (Dialects DialectTable)}

{DialectTable (Dialects [Vec Dialect])}

{Dialect (Kind DialectKind) (Rules [Vec Rule])}


;; ── Second Pass Output (askic) ──────────────────────────────────

{DataTree
  (Root Node)
  Scope}
