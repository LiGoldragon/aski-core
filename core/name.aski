;; name.aski — name domains
;;
;; Every name in an aski program belongs to a domain.
;; The domain classifies the name's syntactic role.
;; Names are scoped — identity comes from position in
;; the scope tree, not from a global registry.

(name NameDomain Operator)

;; ── Name Domains ────────────────────────────────────────────────
;; What KIND of name something is. Not where it lives (scope)
;; or what value it holds.

(NameDomain
  Type Variant Field Trait Method
  Module Binding Literal TypeParam)

;; ── Operators ───────────────────────────────────────────────────
;; Fixed set — not interned, not scoped. The variants are exhaustive.

(Operator
  Add Sub Mul Mod
  Eq NotEq Lt Gt LtEq GtEq
  And Or)
