;; name.aski — name classification
;;
;; Every name in an aski program belongs to a NameDomain —
;; the classification of its syntactic role.

(Name NameDomain Operator)

(NameDomain
  Type Variant Field Trait Method
  Module Literal TypeParam)

(Operator
  Add Sub Mul Mod
  Eq NotEq Lt Gt LtEq GtEq
  And Or)
