;; scope.aski — scope classification
;;
;; Every syntactic construct that introduces names creates a scope.
;; All three domain forms (enum, struct, newtype) create scopes.
;; Scopes nest infinitely. Name resolution walks up from the
;; current scope toward root. First match wins (shadowing).

(Scope ScopeKind Visibility)

(ScopeKind
  Root Module
  Enum Struct Newtype Trait TraitImpl
  Method Block MatchArm Loop Iteration)

(Visibility Exported Local)
